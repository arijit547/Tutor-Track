rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tutors collection - user-scoped access
    match /tutors/{tutorId} {
      // Only authenticated users can access their own tutor document
      allow read, write: if request.auth.uid == tutorId;

      // Profile subcollection
      match /profile/{document=**} {
        allow read, write: if request.auth.uid == tutorId;
      }

      // Students subcollection and all nested documents (sessions, payments)
      match /students/{document=**} {
        allow read, write: if request.auth.uid == tutorId;
      }
    }
  }
}
